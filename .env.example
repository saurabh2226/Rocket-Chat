# Server Port (default: 8080)
PORT=8080

# MongoDB Connection String (required)
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=

# Frontend URL for CORS configuration (required for production)
# Development: http://localhost:3000
# Production: https://your-app-name.onrender.com
FRONTEND_URL=http://localhost:3000

# Firebase Service Account JSON (required for production)
# For local development: leave empty to use serviceAccountKey.json file
# For production (Render): paste your entire Firebase service account JSON as a single-line string
# Example: {"type":"service_account","project_id":"your-project",...}
FIREBASE_SERVICE_ACCOUNT=